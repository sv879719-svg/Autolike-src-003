{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription details",
      "type": "object",
      "properties": {
        "tgId": { "type": "string", "description": "Telegram User ID" },
        "name": { "type": "string", "description": "Telegram Name" },
        "role": { "type": "string", "enum": ["normal", "vip", "autouser", "admin"], "description": "User role" },
        "uid": { "type": "string", "description": "Game UID" },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Subscription expiry date" },
        "lastLikeDate": { "type": "string", "format": "date-time", "description": "Last time the user used the like command" }
      },
      "required": ["tgId", "role"]
    },
    "Config": {
      "title": "Config",
      "description": "Bot global configuration",
      "type": "object",
      "properties": {
        "apiUrl": { "type": "string", "description": "Like API URL template" },
        "adminTgId": { "type": "string", "description": "Main admin Telegram ID" },
        "channelId": { "type": "string", "description": "Logs channel ID" }
      }
    },
    "RedeemCode": {
      "title": "RedeemCode",
      "description": "Gift codes for coins and points",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Unique code string" },
        "coins": { "type": "number", "description": "Number of coins/points awarded" },
        "days": { "type": "number", "description": "Validity period in days" },
        "used": { "type": "boolean", "description": "Whether the code has been used" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "usedBy": { "type": "string", "description": "TG ID of the user who redeemed it" },
        "usedAt": { "type": "string", "format": "date-time", "description": "Redemption timestamp" }
      },
      "required": ["code", "coins", "days", "used", "createdAt"]
    }
  },
  "firestore": {
    "/users/{tgId}": {
      "schema": "User",
      "description": "Collection of bot users"
    },
    "/config/main": {
      "schema": "Config",
      "description": "Global bot settings"
    },
    "/redeemCodes/{code}": {
      "schema": "RedeemCode",
      "description": "Collection of gift codes"
    }
  }
}
